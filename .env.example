# Supabase Configuration
VITE_SUPABASE_PROJECT_ID=your_supabase_project_id
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key
VITE_SUPABASE_URL=https://your-project.supabase.co

# Gumroad Configuration (Frontend - use VITE_ prefix for Vite)
VITE_GUMROAD_PRODUCT_ID=rebelkit
VITE_GUMROAD_SUBDOMAIN=matthewgas

# Supabase Edge Functions Environment Variables
# (Set these in Supabase Dashboard > Edge Functions > Secrets)

# Gumroad Configuration (Backend)
GUMROAD_PRODUCT_ID=rebelkit
GUMROAD_ACCESS_TOKEN=your_gumroad_access_token_here
GUMROAD_WEBHOOK_SECRET=your_webhook_secret_here

# Redirect URL
REDIRECT_URL=https://kindai-showcase-shop.lovable.app/purchase/redirect

# Email Service
RESEND_API_KEY=your_resend_api_key_here

# Supabase (automatically provided in Edge Functions)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
